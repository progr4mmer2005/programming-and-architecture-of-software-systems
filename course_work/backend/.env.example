# Django
DEBUG=True
SECRET_KEY=django-insecure-change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Database engine: "mysql" or "sqlite"
DB_ENGINE=mysql

# Database (MySQL) — only used when DB_ENGINE=mysql
DB_NAME=contracts_db
